{
  "name": "msl-backend",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "MCP Sandbox Layer, Backend mit MCP-Server, Chat-Routing und Study-API",
  "scripts": {
    "dev": "tsx watch src/server/http.ts",
    "mcp:stdio": "tsx src/server/stdio.ts",
    "mcp:http": "tsx src/server/http.ts",
    "seed": "tsx src/scripts/seed-study-template.ts",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\""
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/mcp": "1.0.35",
    "@ai-sdk/openai": "^3.0.48",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^6.0.137",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "fast-json-patch": "^3.1.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.1",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.15.0"
  }
}
