{
  "info": {
    "name": "MSL MCP Sandbox Layer",
    "description": "MSL API Smoke Tests.\n\nOrdner:\n- 01 Ops\n\nVariablen:\n- baseUrl\n- actorId\n- projectId\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:7090",
      "description": "API root"
    },
    {
      "key": "actorId",
      "value": "postman-admin"
    },
    {
      "key": "projectId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 Ops",
      "description": "Health, projects, context",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Backend erreichbar', () => pm.response.to.have.status(200));",
                  "pm.test('ok:true', () => pm.expect(pm.response.json().ok).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "Projekte auflisten",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/projects"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "const first = (body.projects && body.projects.projects) ? body.projects.projects[0] : (body.projects||[])[0];",
                  "if (first) {",
                  "  pm.collectionVariables.set('projectId', first.applicationId || first.id);",
                  "  console.log('projectId gesetzt:', pm.collectionVariables.get('projectId'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Context lesen",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/context"
          }
        },
        {
          "name": "Context setzen",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/context",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": \"{{projectId}}\",\n  \"actorId\": \"{{actorId}}\"\n}"
            }
          }
        }
      ]
    }
  ]
}
