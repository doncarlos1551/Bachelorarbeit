{
  "info": {
    "name": "MSL MCP Sandbox Layer",
    "description": "MSL API smoke tests und Studien-Admin.\n\nOrdner:\n- 01 Ops\n- 02 Study Flow\n- 03 Study Reporting\n- 04 Plans & Approval\n- 05 Chat\n- 06 Ablation\n- 07 Debug\n\nVariablen:\n- baseUrl\n- actorId\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:7090",
      "description": "API root"
    },
    {
      "key": "actorId",
      "value": "postman-admin"
    },
    {
      "key": "projectId",
      "value": ""
    },
    {
      "key": "planId",
      "value": ""
    },
    {
      "key": "studySessionId",
      "value": ""
    },
    {
      "key": "caseRunId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 Ops",
      "description": "Health, config, context",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Backend erreichbar', () => pm.response.to.have.status(200));",
                  "pm.test('ok:true', () => pm.expect(pm.response.json().ok).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "Config lesen",
          "description": "Active gate config",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/config"
          }
        },
        {
          "name": "Projekte auflisten",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/projects"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "const first = (body.projects && body.projects.projects) ? body.projects.projects[0] : (body.projects||[])[0];",
                  "if (first) {",
                  "  pm.collectionVariables.set('projectId', first.applicationId || first.id);",
                  "  console.log('projectId gesetzt:', pm.collectionVariables.get('projectId'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Context lesen",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/context"
          }
        },
        {
          "name": "Context setzen",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/context",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": \"{{projectId}}\",\n  \"actorId\": \"{{actorId}}\"\n}"
            }
          }
        },
        {
          "name": "Queue lesen (alle offenen Plans)",
          "description": "Open approval plans",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/queue"
          }
        }
      ]
    },
    {
      "name": "02 Study Flow",
      "description": "Participant flow, step by step",
      "item": [
        {
          "name": "1. Cases auflisten",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/study/cases"
          }
        },
        {
          "name": "2. Counterbalance-Designs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/study/designs"
          }
        },
        {
          "name": "3. Session erstellen",
          "description": "Session clone plus studySessionId",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/study/sessions",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"participantId\": \"P01\",\n  \"participantGroup\": \"professional_dev\",\n  \"counterbalanceDesignId\": \"A\",\n  \"metadata\": { \"source\": \"postman\" }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.session) {",
                  "  pm.collectionVariables.set('studySessionId', body.session.studySessionId);",
                  "  if (body.projectId) pm.collectionVariables.set('projectId', body.projectId);",
                  "  console.log('studySessionId gesetzt:', body.session.studySessionId);",
                  "  console.log('Case-Sequence:', body.session.caseSequence.join(' -> '));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "4. Case-Run starten",
          "description": "Case run plus caseRunId",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/study/sessions/{{studySessionId}}/case-runs",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"caseId\": \"C01\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.caseRun) {",
                  "  pm.collectionVariables.set('caseRunId', body.caseRun.caseRunId);",
                  "  console.log('caseRunId gesetzt:', body.caseRun.caseRunId);",
                  "  console.log('variant:', body.variant);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "5. Session-Status prüfen",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/study/sessions/{{studySessionId}}"
          }
        },
        {
          "name": "6. Case-Run abschließen",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/study/case-runs/{{caseRunId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}"
            }
          }
        },
        {
          "name": "7. Response erfassen (Ratings)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/study/responses",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studySessionId\": \"{{studySessionId}}\",\n  \"caseRunId\": \"{{caseRunId}}\",\n  \"caseId\": \"C01\",\n  \"variant\": \"diff_risk\",\n  \"decision\": \"approve\",\n  \"correct\": true,\n  \"decisionTimeMs\": 12400,\n  \"trustRating\": 5,\n  \"confidenceRating\": 6,\n  \"transparencyRating\": 5,\n  \"controlRating\": 4,\n  \"notes\": \"Risiko-Anzeige war hilfreich\"\n}"
            }
          }
        },
        {
          "name": "8. Session abschließen",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/study/sessions/{{studySessionId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}"
            }
          }
        },
        {
          "name": "9. Export Session (JSON)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/study/export/{{studySessionId}}"
          }
        },
        {
          "name": "9. Export Session (CSV)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/study/export/{{studySessionId}}/csv"
          }
        }
      ]
    },
    {
      "name": "03 Study Reporting",
      "description": "Sessions, responses, exports",
      "item": [
        {
          "name": "Alle Sessions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/study/sessions"
          }
        },
        {
          "name": "Responses für Session",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/study/responses?studySessionId={{studySessionId}}"
          }
        },
        {
          "name": "Bulk-Export (JSON)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/study/export-all"
          }
        },
        {
          "name": "Bulk-Export (CSV)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/study/export-all/csv"
          }
        },
        {
          "name": "Live-Tasks + Designs",
          "description": "Frontend task catalog",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/study/live-tasks"
          }
        }
      ]
    },
    {
      "name": "04 Plans & Approval",
      "description": "Manual plan review",
      "item": [
        {
          "name": "Plan-Details",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/plans/{{planId}}"
          }
        },
        {
          "name": "Plan-Events",
          "description": "Plan lifecycle events",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/plans/{{planId}}/events"
          }
        },
        {
          "name": "Plan freigeben",
          "description": "Approve plus auto-apply",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/plans/{{planId}}/approve",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actorId\": \"{{actorId}}\",\n  \"comment\": \"Freigabe via Postman\"\n}"
            }
          }
        },
        {
          "name": "Plan ablehnen",
          "description": "Reject active plan",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/plans/{{planId}}/reject",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actorId\": \"{{actorId}}\",\n  \"comment\": \"Abgelehnt via Postman\"\n}"
            }
          }
        },
        {
          "name": "Plan anwenden (explizit)",
          "description": "Explicit apply fallback",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/plans/{{planId}}/apply",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actorId\": \"{{actorId}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "05 Chat (LLM + MCP)",
      "description": "Direct chat smoke tests",
      "item": [
        {
          "name": "Verfügbare Modelle",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/chat/models"
          }
        },
        {
          "name": "Chat-Nachricht senden",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/chat",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Zeige mir die aktuelle Projektstruktur.\",\n  \"projectId\": \"{{projectId}}\",\n  \"model\": \"gpt-4o-mini\"\n}"
            }
          }
        },
        {
          "name": "Chat mit History",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/chat",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Füge einen Button mit Text 'Test' hinzu.\",\n  \"projectId\": \"{{projectId}}\",\n  \"model\": \"gpt-4o-mini\",\n  \"history\": [\n    { \"role\": \"user\", \"content\": \"Zeige die Projektstruktur.\" },\n    { \"role\": \"assistant\", \"content\": \"Das Projekt enthält 5 Komponenten.\" }\n  ]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "06 Ablation (Gate-Konfiguration)",
      "description": "Technical gate ablation presets",
      "item": [
        {
          "name": "Ablation: alle Gates OFF",
          "description": "No MSL baseline",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/config",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gateModes\": {\n    \"policy\": \"off\",\n    \"preflight\": \"off\",\n    \"diff\": \"off\",\n    \"risk\": \"off\",\n    \"validation\": \"off\",\n    \"approval\": \"off\",\n    \"audit\": \"off\"\n  }\n}"
            }
          }
        },
        {
          "name": "Ablation: alle Gates OBSERVE (loggen, nicht blockieren)",
          "description": "Observe-only pipeline",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/config",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"executionMode\": \"auto\",\n  \"gateModes\": {\n    \"policy\": \"observe\",\n    \"preflight\": \"observe\",\n    \"diff\": \"observe\",\n    \"risk\": \"observe\",\n    \"validation\": \"observe\",\n    \"approval\": \"off\",\n    \"audit\": \"observe\"\n  }\n}"
            }
          }
        },
        {
          "name": "Ablation: alle Gates ENFORCE",
          "description": "Full enforced pipeline",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/config",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"executionMode\": \"manual\",\n  \"approvalRiskThreshold\": \"medium\",\n  \"gateModes\": {\n    \"policy\": \"enforce\",\n    \"preflight\": \"observe\",\n    \"diff\": \"observe\",\n    \"risk\": \"observe\",\n    \"validation\": \"enforce\",\n    \"approval\": \"enforce\",\n    \"audit\": \"observe\"\n  }\n}"
            }
          }
        },
        {
          "name": "Ablation: nur Policy",
          "description": "Policy only",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/config",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"executionMode\": \"auto\",\n  \"gateModes\": {\n    \"policy\": \"enforce\",\n    \"preflight\": \"off\",\n    \"diff\": \"off\",\n    \"risk\": \"off\",\n    \"validation\": \"off\",\n    \"approval\": \"off\",\n    \"audit\": \"observe\"\n  }\n}"
            }
          }
        },
        {
          "name": "Ablation: nur Approval",
          "description": "Approval only",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/config",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"executionMode\": \"manual\",\n  \"approvalRiskThreshold\": \"medium\",\n  \"gateModes\": {\n    \"policy\": \"off\",\n    \"preflight\": \"off\",\n    \"diff\": \"off\",\n    \"risk\": \"off\",\n    \"validation\": \"off\",\n    \"approval\": \"enforce\",\n    \"audit\": \"observe\"\n  }\n}"
            }
          }
        },
        {
          "name": "Ablation: Open-Plan-Quota aktivieren",
          "description": "Open-plan quota",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/config",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"openPlanMode\": \"block\",\n  \"maxOpenPlansPerSession\": 3\n}"
            }
          }
        }
      ]
    },
    {
      "name": "07 Debug & Maintenance",
      "description": "Admin maintenance",
      "item": [
        {
          "name": "Variant-Tracking setzen",
          "description": "Variant tracking only",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/study/case-config",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"variant\": \"diff_risk\",\n  \"sessionId\": \"{{studySessionId}}\"\n}"
            }
          }
        },
        {
          "name": "Projekt zuruecksetzen",
          "description": "Restore project from fixture",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/study/reset-project",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": \"{{projectId}}\"\n}"
            }
          }
        },
        {
          "name": "Config patchen (frei)",
          "description": "Free-form config patch",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/config",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"executionMode\": \"manual\",\n  \"approvalRiskThreshold\": \"medium\",\n  \"gateModes\": {\n    \"policy\": \"enforce\",\n    \"preflight\": \"observe\",\n    \"diff\": \"observe\",\n    \"risk\": \"observe\",\n    \"validation\": \"enforce\",\n    \"approval\": \"enforce\",\n    \"audit\": \"observe\"\n  }\n}"
            }
          }
        }
      ]
    }
  ]
}
